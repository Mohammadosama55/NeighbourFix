      ]
    },
    {
      "name": "Complaint API",
      "item": [
        {
          "name": "Create Complaint (with Photo)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_RESIDENT_TOKEN_HERE"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Pothole on Main Street"
                },
                {
                  "key": "description",
                  "value": "Large dangerous pothole causing traffic hazard"
                },
                {
                  "key": "category",
                  "value": "road"
                },
                {
                  "key": "wardNumber",
                  "value": "10"
                },
                {
                  "key": "address",
                  "value": "Main Street, Bangalore"
                },
                {
                  "key": "location",
                  "value": "{\"coordinates\": [77.5994, 12.9716]}"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "src": "UPLOAD_IMAGE_FILE_HERE"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/complaints",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints"]
            }
          }
        },
        {
          "name": "Get All Complaints",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/complaints",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints"]
            }
          }
        },
        {
          "name": "Get Complaint By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/complaints/PASTE_COMPLAINT_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints", "PASTE_COMPLAINT_ID_HERE"]
            }
          }
        },
        {
          "name": "Get Nearby Complaints",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/complaints/nearby?lat=12.9716&lng=77.5994&radius=5000",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints", "nearby"],
              "query": [
                {
                  "key": "lat",
                  "value": "12.9716"
                },
                {
                  "key": "lng",
                  "value": "77.5994"
                },
                {
                  "key": "radius",
                  "value": "5000"
                }
              ]
            }
          }
        },
        {
          "name": "Upvote Complaint",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/complaints/PASTE_COMPLAINT_ID_HERE/upvote",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints", "PASTE_COMPLAINT_ID_HERE", "upvote"]
            }
          }
        },
        {
          "name": "Get Heatmap Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/complaints/heatmap",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints", "heatmap"]
            }
          }
        },
        {
          "name": "Update Status (Admin Only)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ADMIN_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/complaints/PASTE_COMPLAINT_ID_HERE/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints", "PASTE_COMPLAINT_ID_HERE", "status"]
            }
          }
        },
        {
          "name": "Resolve Complaint (Admin Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ADMIN_TOKEN_HERE"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "resolutionNotes",
                  "value": "Pothole filled with asphalt"
                },
                {
                  "key": "resolutionPhotos",
                  "type": "file",
                  "src": "UPLOAD_BEFORE_AFTER_PHOTOS"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/complaints/PASTE_COMPLAINT_ID_HERE/resolve",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints", "PASTE_COMPLAINT_ID_HERE", "resolve"]
            }
          }
        }
      ]
    }
  ]
}
