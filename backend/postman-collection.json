{
  "info": {
    "name": "NeighbourFix API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth API",
      "item": [
        {
          "name": "Register Resident",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Resident\",\n  \"email\": \"john@test.com\",\n  \"password\": \"Password123!\",\n  \"phone\": \"9876543210\",\n  \"role\": \"resident\",\n  \"wardNumber\": \"10\",\n  \"address\": \"123 Main Street\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Officer\",\n  \"email\": \"admin@municipality.gov\",\n  \"password\": \"AdminPass123!\",\n  \"phone\": \"1234567890\",\n  \"role\": \"ward_admin\",\n  \"wardNumber\": \"10\",\n  \"address\": \"Municipal Office\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
